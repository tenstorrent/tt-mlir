    %350 = stablehlo.transpose %349, dims = [1, 0] {result_layout = dense<[0, 1]> : tensor<2xindex>, xla_shape = "bf16[1024,1000]{0,1}"} : (tensor<1000x1024xbf16>) -> tensor<1024x1000xbf16> loc(#loc)
    %351 = stablehlo.convert %350 {result_layout = dense<[0, 1]> : tensor<2xindex>, xla_shape = "f32[1024,1000]{0,1}"} : (tensor<1024x1000xbf16>) -> tensor<1024x1000xf32> loc(#loc)
    %352 = stablehlo.dot_general %347, %351, contracting_dims = [1] x [0] : (tensor<1x1024xf32>, tensor<1024x1000xf32>) -> tensor<1x1000xf32> loc(#loc)
