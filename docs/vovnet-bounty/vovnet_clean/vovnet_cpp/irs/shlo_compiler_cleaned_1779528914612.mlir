    %357 = stablehlo.add %352, %356 : tensor<1x1000xf32> loc(#loc)
    %358 = stablehlo.convert %357 : (tensor<1x1000xf32>) -> tensor<1x1000xbf16> loc(#loc)
    return %358 : tensor<1x1000xbf16> loc(#loc)
  } loc(#loc)
} loc(#loc)
