sequenceDiagram
    participant TTRT as TTRT Runtime<br/>(RtApi.Run)
    participant PRE as preop() Callback
    participant DEV as Device Hardware<br/>(TT Accelerator)
    participant POST as postop() Callback
    participant REG as Registry<br/>(OpGroups by location)
    participant DP as Device TensorPool
    participant GE as GoldenExecutor
    participant GP as Golden TensorPool
    participant GL as Golden Library<br/>(GOLDEN_MAPPINGS)
    participant CMP as compare_outputs()
    participant RPT as ReportWriter (CSV)

    Note over TTRT,RPT: DebugHooks.get(preop, postop) registered at startup

    loop For each device op in flatbuffer
        TTRT->>PRE: preop(binary, programContext, opContext)
        activate PRE

        PRE->>PRE: get_op_debug_str(opContext)
        PRE->>PRE: parse_op_location(get_op_loc_info(opContext))
        PRE->>PRE: get_op_input_refs(opContext, programContext)

        alt No input refs
            PRE-->>TTRT: return (skip)
        end

        PRE->>REG: find_op(location, debug_str, DEVICE)
        REG-->>PRE: current_device_op (or None)

        alt Op not found in registry
            PRE-->>TTRT: return (skip)
        end

        PRE->>PRE: get_op_inputs(current_device_op)

        loop For each (mlir_tensor, tensor_ref) pair
            alt Tensor already in pool
                PRE->>DP: lookup device_tensor_pool[input_name]
                DP-->>PRE: existing TensorValue

                alt tensor_ref already set
                    Note over PRE: Skip - reference exists
                else tensor_ref is None
                    PRE->>PRE: Set tensor_ref on TensorValue
                    PRE->>PRE: function_argument_bridge()

                    alt bridge_type == "host"
                        PRE->>DP: device_tensor.update_tensor_in_pool()
                        Note over DP: Push host data → device memory<br/>(create_owned_host_tensor +<br/>update_tensor_in_pool)
                    else bridge_type == "device"
                        PRE->>DP: retrieve_tensor_from_pool()
                        PRE->>GP: Create golden TensorValue<br/>from device data
                    end
                end
            else Tensor NOT in pool
                PRE->>DEV: retrieve_tensor_from_pool(programCtx, ref)
                DEV-->>PRE: RtTensor data
                PRE->>PRE: get_torch_tensor(tensor_data)
                PRE->>DP: Store new TensorValue(name, data, DEVICE, ref)
            end
        end

        deactivate PRE

        Note over DEV: Device op executes on TT hardware

        TTRT->>POST: postop(binary, programContext, opContext)
        activate POST

        POST->>POST: get_op_debug_str(opContext)
        POST->>POST: parse_op_location(get_op_loc_info(opContext))

        alt current_device_op is None
            POST-->>TTRT: return (skip)
        end

        alt Op has no outputs
            POST-->>TTRT: return (skip)
        end

        POST->>POST: output_name = get_op_outputs(op)[0].get_name()
        POST->>DEV: get_op_output_ref(opContext, programContext)
        DEV-->>POST: output_ref

        alt output_ref is None
            POST-->>TTRT: return (skip)
        end

        POST->>DEV: retrieve_tensor_from_pool(programCtx, output_ref)
        DEV-->>POST: output RtTensor
        POST->>POST: get_torch_tensor(output_tensor)
        POST->>DP: Store TensorValue(output_name, data, DEVICE, ref)

        POST->>REG: should_compare(op, location, DEVICE)
        REG-->>POST: is this the last op in the group?

        alt should_compare == True
            POST->>GE: execute_golden(op_location, debug_str)
            activate GE

            Note over GE: Find target_index from<br/>golden_module.last_loc_line[location]

            loop For each golden op up to target_index
                GE->>GE: execute(op)

                alt op is ttir.empty
                    Note over GE: Skip (return None)
                else op is func.return
                    GE->>GP: Return input tensor from pool
                else Normal op
                    GE->>GL: get_golden_function(type(op))
                    GL-->>GE: golden_fn (PyTorch impl)

                    GE->>GP: Retrieve input tensors by name
                    GP-->>GE: execution_data tensors

                    alt ttir.dot_general
                        GE->>GE: Handle batch/contract dims<br/>torch.tensordot or golden_fn
                    else ttir.broadcast
                        GE->>GE: Get target shape from output type
                    else ttir.pad
                        GE->>GE: Extract padding + value attrs
                    else ttir.permute
                        GE->>GE: Extract permutation attr
                    else Standard op
                        GE->>GE: golden_fn(*inputs)
                    end

                    GE->>GP: Store result as TensorValue<br/>(set execution_data)
                end
            end

            deactivate GE

            alt skip_group is True
                POST->>POST: skip_group(location, programCtx)
                Note over POST,GP: Sync device inputs → golden inputs<br/>Execute golden ops with skip<br/>Push golden output → device memory
            end

            POST->>CMP: compare_outputs(op_location)
            activate CMP

            CMP->>REG: get_group_output(loc, DEVICE)
            REG-->>CMP: device output tensor ref
            CMP->>DP: Lookup device output data
            DP-->>CMP: device_output (torch.Tensor)

            CMP->>REG: get_group_output(loc, GOLDEN)
            REG-->>CMP: golden output tensor ref
            CMP->>GP: Lookup golden output data
            GP-->>CMP: golden_output (torch.Tensor)

            Note over CMP: _to_common_shape()<br/>squeeze → broadcast → permute → flatten

            CMP->>CMP: compute_pcc(device, golden)<br/>Pearson correlation coefficient
            CMP->>CMP: compute_abs_err(device, golden)<br/>max |device - golden|
            CMP->>CMP: compute_rel_err(device, golden)<br/>max |(d-g)/(g+ε)|

            CMP->>RPT: write_row(location, ops,<br/>tensors, pcc, abs_err, rel_err)

            deactivate CMP
        end

        deactivate POST
    end
