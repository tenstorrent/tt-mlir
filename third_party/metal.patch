From 37c9fa40f87a1e36f1341beea1171954b3e6f132 Mon Sep 17 00:00:00 2001
From: brataTT <achoudhury@tenstorrent.com>
Date: Fri, 20 Jun 2025 12:14:49 +0000
Subject: [PATCH] Workaround to allow multiple definitions

---
 ttnn/CMakeLists.txt | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/ttnn/CMakeLists.txt b/ttnn/CMakeLists.txt
index ac1e5a08a8..3f22c06eac 100644
--- a/ttnn/CMakeLists.txt
+++ b/ttnn/CMakeLists.txt
@@ -357,6 +357,10 @@ endif()
 # for those who need this second use case, now it is officially supported

 add_library(ttnncpp ${TTNN_CPP_BUILD_TYPE})
+# Workaround for duplicate symbols: allow multiple definitions
+if (CMAKE_CXX_COMPILER_ID MATCHES "Clang|GNU")
+    target_link_options(ttnncpp PRIVATE "-Wl,--allow-multiple-definition")
+endif()
 add_library(TTNN::CPP ALIAS ttnncpp)
 add_library(Metalium::TTNNCPP ALIAS ttnncpp) # backwards compatibility. FIXME: remove

