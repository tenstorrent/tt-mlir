{
    "version": 4,
    "configurePresets": [
      {
        "name": "debug",
        "displayName": "Debug and custom flags",
        "generator": "Ninja",
        "binaryDir": "${sourceDir}/build",
        "cacheVariables": {
          "CMAKE_BUILD_TYPE": "Debug",
          "CMAKE_C_COMPILER": "clang",
          "CMAKE_CXX_COMPILER": "clang++",
          "CMAKE_C_COMPILER_LAUNCHER": "ccache",
          "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
          "CMAKE_EXPORT_COMPILE_COMMANDS": "YES",
          "TTMLIR_ENABLE_EXPLORER": "ON",
          "TT_RUNTIME_DEBUG": "ON",
          "TT_RUNTIME_ENABLE_PERF_TRACE": "ON",
          "TTMLIR_ENABLE_RUNTIME": "ON",
          "TTMLIR_ENABLE_OPMODEL": "ON",
          "TTMLIR_ENABLE_STABLEHLO": "ON",
          "CMAKE_C_FLAGS": "-fdebug-prefix-map=${sourceDir}=/tt-mlir -fmacro-prefix-map=${sourceDir}=/tt-mlir",
          "CMAKE_CXX_FLAGS": "-fdebug-prefix-map=${sourceDir}=/tt-mlir -fmacro-prefix-map=${sourceDir}=/tt-mlir"
        },
        "cmakeExecutable": "sea_cmake"
      }
    ]
}

