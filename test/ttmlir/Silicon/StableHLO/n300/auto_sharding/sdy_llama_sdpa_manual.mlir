module @SyncTensorsGraph.95 attributes {mhlo.cross_program_prefetches = [], mhlo.input_output_alias = [], mhlo.is_dynamic = false, mhlo.use_auto_spmd_partitioning = false} {
  sdy.mesh @mesh = <["_axis_0"=2]> loc(#loc)
  func.func @main(%arg0: tensor<1x8x1024x64xbf16> {sdy.sharding = #sdy.sharding<@mesh, [{}, {"_axis_0"}, {}, {}]>} loc("p0.1"), %arg1: tensor<1x1x1024x1024xbf16> {sdy.sharding = #sdy.sharding<@mesh, [{}, {}, {}, {}]>} loc("p1.10"), %arg2: tensor<1x8x1024x64xbf16> {sdy.sharding = #sdy.sharding<@mesh, [{}, {"_axis_0"}, {}, {}]>} loc("p2.13"), %arg3: tensor<1x32x1024x64xbf16> {sdy.sharding = #sdy.sharding<@mesh, [{}, {"_axis_0"}, {}, {}]>} loc("p3.25")) -> tensor<1x1024x32x64xbf16> {
    %0 = sdy.constant dense<0.000000e+00> : tensor<f32> loc(#loc)
    %1 = stablehlo.broadcast_in_dim %0, dims = [] : (tensor<f32>) -> tensor<1x32x1024x1024xf32> loc(#loc)
    %2 = sdy.constant dense<0xFFF0000000000000> : tensor<f64> loc(#loc)
    %3 = stablehlo.broadcast_in_dim %2, dims = [] : (tensor<f64>) -> tensor<1x32x1024x1024xf64> loc(#loc)
    %4 = sdy.constant dense<0.353553385> : tensor<f32> loc(#loc)
    %5 = stablehlo.broadcast_in_dim %4, dims = [] : (tensor<f32>) -> tensor<1x32x64x1024xf32> loc(#loc)
    %6 = sdy.constant dense<0.353553385> : tensor<f32> loc(#loc)
    %7 = stablehlo.broadcast_in_dim %6, dims = [] : (tensor<f32>) -> tensor<1x32x1024x64xf32> loc(#loc)
    %8 = sdy.constant dense<0xFF800000> : tensor<f32> loc(#loc)
    %9 = sdy.constant dense<0.000000e+00> : tensor<f32> loc(#loc)
    %10 = sdy.constant dense<false> : tensor<i1> loc(#loc)
    %11 = stablehlo.custom_call @tt.mark_argument(%arg3) {api_version = 0 : i32, mhlo.frontend_attributes = {ttcore.argument_type = "input", ttir.name = "args_3"}} : (tensor<1x32x1024x64xbf16>) -> tensor<1x32x1024x64xbf16> loc(#loc5)
    %12 = stablehlo.convert %11 : (tensor<1x32x1024x64xbf16>) -> tensor<1x32x1024x64xf32> loc(#loc6)
    %13 = stablehlo.multiply %12, %7 : tensor<1x32x1024x64xf32> loc(#loc7)
    %14 = stablehlo.custom_call @tt.mark_argument(%arg2) {api_version = 0 : i32, mhlo.frontend_attributes = {ttcore.argument_type = "input", ttir.name = "args_1"}} : (tensor<1x8x1024x64xbf16>) -> tensor<1x8x1024x64xbf16> loc(#loc8)
    %15 = stablehlo.broadcast_in_dim %14, dims = [0, 1, 3, 4] : (tensor<1x8x1024x64xbf16>) -> tensor<1x8x4x1024x64xbf16> loc(#loc9)
    %16 = stablehlo.reshape %15 : (tensor<1x8x4x1024x64xbf16>) -> tensor<1x32x1024x64xbf16> loc(#loc10)
    %17 = stablehlo.convert %16 : (tensor<1x32x1024x64xbf16>) -> tensor<1x32x1024x64xf32> loc(#loc11)
    %18 = stablehlo.transpose %17, dims = [0, 1, 3, 2] {result_layout = dense<[2, 3, 1, 0]> : tensor<4xindex>, xla_shape = "f32[1,32,64,1024]{2,3,1,0}"} : (tensor<1x32x1024x64xf32>) -> tensor<1x32x64x1024xf32> loc(#loc12)
    %19 = stablehlo.multiply %18, %5 : tensor<1x32x64x1024xf32> loc(#loc13)
    %20 = stablehlo.dot_general %13, %19, batching_dims = [0, 1] x [0, 1], contracting_dims = [3] x [2] {mhlo.frontend_attributes = {grad_x = "false", grad_y = "false"}} : (tensor<1x32x1024x64xf32>, tensor<1x32x64x1024xf32>) -> tensor<1x32x1024x1024xf32> loc(#loc14)
    %21 = stablehlo.custom_call @tt.mark_argument(%arg1) {api_version = 0 : i32, mhlo.frontend_attributes = {ttcore.argument_type = "input", ttir.name = "args_0"}} : (tensor<1x1x1024x1024xbf16>) -> tensor<1x1x1024x1024xbf16> loc(#loc15)
    %22 = stablehlo.convert %21 : (tensor<1x1x1024x1024xbf16>) -> tensor<1x1x1024x1024xf32> loc(#loc16)
    %23 = stablehlo.reshape %22 : (tensor<1x1x1024x1024xf32>) -> tensor<1x1024x1024xf32> loc(#loc17)
    %24 = stablehlo.broadcast_in_dim %23, dims = [0, 2, 3] : (tensor<1x1024x1024xf32>) -> tensor<1x32x1024x1024xf32> loc(#loc18)
    %25 = stablehlo.add %20, %24 : tensor<1x32x1024x1024xf32> loc(#loc19)
    %26 = stablehlo.convert %25 : (tensor<1x32x1024x1024xf32>) -> tensor<1x32x1024x1024xf64> loc(#loc20)
    %27 = stablehlo.compare  EQ, %26, %3 : (tensor<1x32x1024x1024xf64>, tensor<1x32x1024x1024xf64>) -> tensor<1x32x1024x1024xi1> loc(#loc21)
    %28 = stablehlo.not %27 : tensor<1x32x1024x1024xi1> loc(#loc22)
    %29 = stablehlo.reduce(%28 init: %10) across dimensions = [3] : (tensor<1x32x1024x1024xi1>, tensor<i1>) -> tensor<1x32x1024xi1>
     reducer(%arg4: tensor<i1> loc("reduce.79"), %arg5: tensor<i1> loc("reduce.79"))  {
      %49 = sdy.constant dense<true> : tensor<i1> loc(#loc)
      %50 = sdy.constant dense<false> : tensor<i1> loc(#loc)
      %51 = stablehlo.or %arg4, %arg5 : tensor<i1> loc(#loc24)
      %52 = stablehlo.select %51, %49, %50 : tensor<i1>, tensor<i1> loc(#loc25)
      stablehlo.return %52 : tensor<i1> loc(#loc)
    } loc(#loc23)
    %30 = stablehlo.reshape %29 : (tensor<1x32x1024xi1>) -> tensor<1x32x1024x1xi1> loc(#loc26)
    %31 = stablehlo.not %30 : tensor<1x32x1024x1xi1> loc(#loc27)
    %32 = stablehlo.reshape %31 : (tensor<1x32x1024x1xi1>) -> tensor<1x32x1024xi1> loc(#loc28)
    %33 = stablehlo.broadcast_in_dim %32, dims = [0, 1, 2] : (tensor<1x32x1024xi1>) -> tensor<1x32x1024x1024xi1> loc(#loc29)
    %34 = stablehlo.reduce(%25 init: %8) applies stablehlo.maximum across dimensions = [3] : (tensor<1x32x1024x1024xf32>, tensor<f32>) -> tensor<1x32x1024xf32> loc(#loc30)
    %35 = stablehlo.broadcast_in_dim %34, dims = [0, 1, 2] : (tensor<1x32x1024xf32>) -> tensor<1x32x1024x1024xf32> loc(#loc31)
    %36 = stablehlo.subtract %25, %35 : tensor<1x32x1024x1024xf32> loc(#loc32)
    %37 = stablehlo.exponential %36 : tensor<1x32x1024x1024xf32> loc(#loc33)
    %38 = stablehlo.reduce(%37 init: %9) applies stablehlo.add across dimensions = [3] : (tensor<1x32x1024x1024xf32>, tensor<f32>) -> tensor<1x32x1024xf32> loc(#loc34)
    %39 = stablehlo.broadcast_in_dim %38, dims = [0, 1, 2] : (tensor<1x32x1024xf32>) -> tensor<1x32x1024x1024xf32> loc(#loc35)
    %40 = stablehlo.divide %37, %39 : tensor<1x32x1024x1024xf32> loc(#loc36)
    %41 = stablehlo.select %33, %1, %40 : tensor<1x32x1024x1024xi1>, tensor<1x32x1024x1024xf32> loc(#loc37)
    %42 = stablehlo.custom_call @tt.mark_argument(%arg0) {api_version = 0 : i32, mhlo.frontend_attributes = {ttcore.argument_type = "input", ttir.name = "args_2"}} : (tensor<1x8x1024x64xbf16>) -> tensor<1x8x1024x64xbf16> loc(#loc38)
    %43 = stablehlo.broadcast_in_dim %42, dims = [0, 1, 3, 4] : (tensor<1x8x1024x64xbf16>) -> tensor<1x8x4x1024x64xbf16> loc(#loc39)
    %44 = stablehlo.reshape %43 : (tensor<1x8x4x1024x64xbf16>) -> tensor<1x32x1024x64xbf16> loc(#loc40)
    %45 = stablehlo.convert %44 : (tensor<1x32x1024x64xbf16>) -> tensor<1x32x1024x64xf32> loc(#loc41)
    %46 = stablehlo.dot_general %41, %45, batching_dims = [0, 1] x [0, 1], contracting_dims = [3] x [2] {mhlo.frontend_attributes = {grad_x = "false", grad_y = "false"}} : (tensor<1x32x1024x1024xf32>, tensor<1x32x1024x64xf32>) -> tensor<1x32x1024x64xf32> loc(#loc42)
    %47 = stablehlo.convert %46 : (tensor<1x32x1024x64xf32>) -> tensor<1x32x1024x64xbf16> loc(#loc43)
    %48 = stablehlo.transpose %47, dims = [0, 2, 1, 3] {result_layout = dense<[3, 1, 2, 0]> : tensor<4xindex>, xla_shape = "bf16[1,1024,32,64]{3,1,2,0}"} : (tensor<1x32x1024x64xbf16>) -> tensor<1x1024x32x64xbf16> loc(#loc44)
    return %48 : tensor<1x1024x32x64xbf16> loc(#loc)
  } loc(#loc)
} loc(#loc)
