// REQUIRES: stablehlo
// RUN: ttmlir-opt --stablehlo-pipeline="mesh-shape=1,2 enable-auto-sharding=true" --stablehlo-to-ttir-pipeline --ttir-to-ttnn-backend-pipeline="system-desc-path=%system_desc_path% mesh-shape=1,2" -o %t.mlir %s
// RUN: ttmlir-translate --ttnn-to-flatbuffer -o %t.ttnn %t.mlir

#loc1 = loc("p0.1")
#loc2 = loc("p1.6")
#loc3 = loc("p2.11")
#loc4 = loc("p3.18")
#loc5 = loc("p4.29")
module @SyncTensorsGraph.66 attributes {mhlo.cross_program_prefetches = [], mhlo.input_output_alias = [], mhlo.is_dynamic = false, mhlo.num_partitions = 2 : i32, mhlo.num_replicas = 1 : i32, mhlo.use_auto_spmd_partitioning = false} {
  sdy.mesh @mesh = <["_axis_0"=2]> loc(#loc)
  func.func @main(%arg0: tensor<512x512xbf16> loc("p0.1"), %arg1: tensor<512x512xbf16> loc("p1.6"), %arg2: tensor<2x128x512xbf16> loc("p2.11"), %arg3: tensor<512x512xbf16> loc("p3.18"), %arg4: tensor<512x512xbf16> loc("p4.29")) -> tensor<2x128x512xbf16> {
    %0 = sdy.constant dense<0.000000e+00> : tensor<bf16> loc(#loc)
    %1 = sdy.constant dense<0xFF80> : tensor<bf16> loc(#loc)
    %3 = stablehlo.reshape %arg2 : (tensor<2x128x512xbf16>) -> tensor<256x512xbf16> loc(#loc7)
    %4 = stablehlo.reshape %arg4 : (tensor<512x512xbf16>) -> tensor<1x512x512xbf16> loc(#loc8)
    %6 = stablehlo.reshape %4 : (tensor<1x512x512xbf16>) -> tensor<512x512xbf16> loc(#loc10)
    %7 = stablehlo.transpose %6, dims = [1, 0] {result_layout = dense<[0, 1]> : tensor<2xindex>, xla_shape = "bf16[512,512]{0,1}"} : (tensor<512x512xbf16>) -> tensor<512x512xbf16> loc(#loc11)
    %8 = stablehlo.dot_general %3, %7, contracting_dims = [1] x [0] : (tensor<256x512xbf16>, tensor<512x512xbf16>) -> tensor<256x512xbf16> loc(#loc12)
    %9 = stablehlo.reshape %8 : (tensor<256x512xbf16>) -> tensor<2x128x8x64xbf16> loc(#loc13)
    %10 = stablehlo.transpose %9, dims = [0, 2, 1, 3] {result_layout = dense<[3, 1, 2, 0]> : tensor<4xindex>, xla_shape = "bf16[2,8,128,64]{3,1,2,0}"} : (tensor<2x128x8x64xbf16>) -> tensor<2x8x128x64xbf16> loc(#loc14)
    %11 = stablehlo.reshape %arg3 : (tensor<512x512xbf16>) -> tensor<1x512x512xbf16> loc(#loc15)
    %13 = stablehlo.reshape %11 : (tensor<1x512x512xbf16>) -> tensor<512x512xbf16> loc(#loc17)
    %14 = stablehlo.transpose %13, dims = [1, 0] {result_layout = dense<[0, 1]> : tensor<2xindex>, xla_shape = "bf16[512,512]{0,1}"} : (tensor<512x512xbf16>) -> tensor<512x512xbf16> loc(#loc18)
    %15 = stablehlo.dot_general %3, %14, contracting_dims = [1] x [0] : (tensor<256x512xbf16>, tensor<512x512xbf16>) -> tensor<256x512xbf16> loc(#loc19)
    %16 = stablehlo.reshape %15 : (tensor<256x512xbf16>) -> tensor<2x128x8x64xbf16> loc(#loc20)
    %17 = stablehlo.transpose %16, dims = [0, 2, 3, 1] : (tensor<2x128x8x64xbf16>) -> tensor<2x8x64x128xbf16> loc(#loc21)
    %18 = stablehlo.dot_general %10, %17, batching_dims = [0, 1] x [0, 1], contracting_dims = [3] x [2] {mhlo.frontend_attributes = {grad_x = "false", grad_y = "false"}} : (tensor<2x8x128x64xbf16>, tensor<2x8x64x128xbf16>) -> tensor<2x8x128x128xbf16> loc(#loc22)
    %19 = stablehlo.reduce(%18 init: %1) applies stablehlo.maximum across dimensions = [3] : (tensor<2x8x128x128xbf16>, tensor<bf16>) -> tensor<2x8x128xbf16> loc(#loc23)
    %20 = stablehlo.broadcast_in_dim %19, dims = [0, 1, 2] : (tensor<2x8x128xbf16>) -> tensor<2x8x128x128xbf16> loc(#loc24)
    %21 = stablehlo.subtract %18, %20 : tensor<2x8x128x128xbf16> loc(#loc25)
    %22 = stablehlo.exponential %21 : tensor<2x8x128x128xbf16> loc(#loc26)
    %23 = stablehlo.reduce(%22 init: %0) applies stablehlo.add across dimensions = [3] : (tensor<2x8x128x128xbf16>, tensor<bf16>) -> tensor<2x8x128xbf16> loc(#loc27)
    %24 = stablehlo.broadcast_in_dim %23, dims = [0, 1, 2] : (tensor<2x8x128xbf16>) -> tensor<2x8x128x128xbf16> loc(#loc28)
    %25 = stablehlo.divide %22, %24 : tensor<2x8x128x128xbf16> loc(#loc29)
    %26 = stablehlo.reshape %arg1 : (tensor<512x512xbf16>) -> tensor<1x512x512xbf16> loc(#loc30)
    %28 = stablehlo.reshape %26 : (tensor<1x512x512xbf16>) -> tensor<512x512xbf16> loc(#loc32)
    %29 = stablehlo.transpose %28, dims = [1, 0] {result_layout = dense<[0, 1]> : tensor<2xindex>, xla_shape = "bf16[512,512]{0,1}"} : (tensor<512x512xbf16>) -> tensor<512x512xbf16> loc(#loc33)
    %30 = stablehlo.dot_general %3, %29, contracting_dims = [1] x [0] : (tensor<256x512xbf16>, tensor<512x512xbf16>) -> tensor<256x512xbf16> loc(#loc34)
    %31 = stablehlo.reshape %30 : (tensor<256x512xbf16>) -> tensor<2x128x8x64xbf16> loc(#loc35)
    %32 = stablehlo.transpose %31, dims = [0, 2, 1, 3] {result_layout = dense<[3, 1, 2, 0]> : tensor<4xindex>, xla_shape = "bf16[2,8,128,64]{3,1,2,0}"} : (tensor<2x128x8x64xbf16>) -> tensor<2x8x128x64xbf16> loc(#loc36)
    %33 = stablehlo.dot_general %25, %32, batching_dims = [0, 1] x [0, 1], contracting_dims = [3] x [2] {mhlo.frontend_attributes = {grad_x = "false", grad_y = "false"}} : (tensor<2x8x128x128xbf16>, tensor<2x8x128x64xbf16>) -> tensor<2x8x128x64xbf16> loc(#loc37)
    %34 = stablehlo.transpose %33, dims = [0, 2, 1, 3] {result_layout = dense<[3, 1, 2, 0]> : tensor<4xindex>, xla_shape = "bf16[2,128,8,64]{3,1,2,0}"} : (tensor<2x8x128x64xbf16>) -> tensor<2x128x8x64xbf16> loc(#loc38)
    %35 = stablehlo.reshape %34 : (tensor<2x128x8x64xbf16>) -> tensor<256x512xbf16> loc(#loc39)
    %36 = stablehlo.reshape %arg0 : (tensor<512x512xbf16>) -> tensor<1x512x512xbf16> loc(#loc40)
    %38 = stablehlo.reshape %36 : (tensor<1x512x512xbf16>) -> tensor<512x512xbf16> loc(#loc42)
    %39 = stablehlo.transpose %38, dims = [1, 0] {result_layout = dense<[0, 1]> : tensor<2xindex>, xla_shape = "bf16[512,512]{0,1}"} : (tensor<512x512xbf16>) -> tensor<512x512xbf16> loc(#loc43)
    %40 = stablehlo.dot_general %35, %39, contracting_dims = [1] x [0] : (tensor<256x512xbf16>, tensor<512x512xbf16>) -> tensor<256x512xbf16> loc(#loc44)
    %41 = stablehlo.reshape %40 : (tensor<256x512xbf16>) -> tensor<2x128x512xbf16> loc(#loc45)
    return %41 : tensor<2x128x512xbf16> loc(#loc)
  } loc(#loc)
} loc(#loc)
