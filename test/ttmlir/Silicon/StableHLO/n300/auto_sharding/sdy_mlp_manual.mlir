// REQUIRES: stablehlo
// RUN: ttmlir-opt --stablehlo-pipeline="mesh-shape=1,2" --stablehlo-to-ttir-pipeline --ttir-to-ttnn-backend-pipeline="system-desc-path=%system_desc_path% mesh-shape=1,2" -o %t.mlir %s
// RUN: ttmlir-translate --ttnn-to-flatbuffer -o %t.ttnn %t.mlir

#loc1 = loc("p0.1")
#loc2 = loc("p1.6")
#loc3 = loc("p2.11")
#loc4 = loc("p3.16")
module @SyncTensorsGraph.33 attributes {mhlo.cross_program_prefetches = [], mhlo.input_output_alias = [], mhlo.is_dynamic = false, mhlo.use_auto_spmd_partitioning = false} {
  sdy.mesh @mesh = <["_axis_0"=2]> loc(#loc)
  func.func @main(%arg0: tensor<2048x8192xbf16> {sdy.sharding = #sdy.sharding<@mesh, [{}, {"_axis_0"}]>} loc("p0.1"), %arg1: tensor<8192x2048xbf16> {sdy.sharding = #sdy.sharding<@mesh, [{"_axis_0"}, {}]>} loc("p1.6"), %arg2: tensor<1x1024x2048xbf16> {sdy.sharding = #sdy.sharding<@mesh, [{}, {}, {}]>} loc("p2.11"), %arg3: tensor<8192x2048xbf16> {sdy.sharding = #sdy.sharding<@mesh, [{"_axis_0"}, {}]>} loc("p3.16")) -> tensor<1x1024x2048xbf16> {
    %0 = stablehlo.custom_call @tt.mark_argument(%arg2) {api_version = 0 : i32, mhlo.frontend_attributes = {ttcore.argument_type = "input", ttir.name = "args_0"}} : (tensor<1x1024x2048xbf16>) -> tensor<1x1024x2048xbf16> loc(#loc5)
    %1 = stablehlo.reshape %0 : (tensor<1x1024x2048xbf16>) -> tensor<1024x2048xbf16> loc(#loc6)
    %2 = stablehlo.reshape %arg3 : (tensor<8192x2048xbf16>) -> tensor<1x8192x2048xbf16> loc(#loc7)
    %3 = stablehlo.custom_call @tt.mark_argument(%2) {api_version = 0 : i32, mhlo.frontend_attributes = {ttcore.argument_type = "parameter", ttir.name = "gate_proj.weight"}} : (tensor<1x8192x2048xbf16>) -> tensor<1x8192x2048xbf16> loc(#loc8)
    %4 = stablehlo.reshape %3 : (tensor<1x8192x2048xbf16>) -> tensor<8192x2048xbf16> loc(#loc9)
    %5 = stablehlo.transpose %4, dims = [1, 0] {result_layout = dense<[0, 1]> : tensor<2xindex>, xla_shape = "bf16[2048,8192]{0,1}"} : (tensor<8192x2048xbf16>) -> tensor<2048x8192xbf16> loc(#loc10)
    %6 = stablehlo.dot_general %1, %5, contracting_dims = [1] x [0] : (tensor<1024x2048xbf16>, tensor<2048x8192xbf16>) -> tensor<1024x8192xbf16> loc(#loc11)
    %7 = stablehlo.reshape %6 : (tensor<1024x8192xbf16>) -> tensor<1x1024x8192xbf16> loc(#loc12)
    %8 = stablehlo.convert %7 : (tensor<1x1024x8192xbf16>) -> tensor<1x1024x8192xf32> loc(#loc13)
    %9 = stablehlo.logistic %8 : tensor<1x1024x8192xf32> loc(#loc14)
    %10 = stablehlo.multiply %8, %9 : tensor<1x1024x8192xf32> loc(#loc15)
    %11 = stablehlo.convert %10 : (tensor<1x1024x8192xf32>) -> tensor<1x1024x8192xbf16> loc(#loc16)
    %12 = stablehlo.reshape %arg1 : (tensor<8192x2048xbf16>) -> tensor<1x8192x2048xbf16> loc(#loc17)
    %13 = stablehlo.custom_call @tt.mark_argument(%12) {api_version = 0 : i32, mhlo.frontend_attributes = {ttcore.argument_type = "parameter", ttir.name = "up_proj.weight"}} : (tensor<1x8192x2048xbf16>) -> tensor<1x8192x2048xbf16> loc(#loc18)
    %14 = stablehlo.reshape %13 : (tensor<1x8192x2048xbf16>) -> tensor<8192x2048xbf16> loc(#loc19)
    %15 = stablehlo.transpose %14, dims = [1, 0] {result_layout = dense<[0, 1]> : tensor<2xindex>, xla_shape = "bf16[2048,8192]{0,1}"} : (tensor<8192x2048xbf16>) -> tensor<2048x8192xbf16> loc(#loc20)
    %16 = stablehlo.dot_general %1, %15, contracting_dims = [1] x [0] : (tensor<1024x2048xbf16>, tensor<2048x8192xbf16>) -> tensor<1024x8192xbf16> loc(#loc21)
    %17 = stablehlo.reshape %16 : (tensor<1024x8192xbf16>) -> tensor<1x1024x8192xbf16> loc(#loc22)
    %18 = stablehlo.multiply %11, %17 : tensor<1x1024x8192xbf16> loc(#loc23)
    %19 = stablehlo.reshape %18 : (tensor<1x1024x8192xbf16>) -> tensor<1024x8192xbf16> loc(#loc24)
    %20 = stablehlo.reshape %arg0 : (tensor<2048x8192xbf16>) -> tensor<1x2048x8192xbf16> loc(#loc25)
    %21 = stablehlo.custom_call @tt.mark_argument(%20) {api_version = 0 : i32, mhlo.frontend_attributes = {ttcore.argument_type = "parameter", ttir.name = "down_proj.weight"}} : (tensor<1x2048x8192xbf16>) -> tensor<1x2048x8192xbf16> loc(#loc26)
    %22 = stablehlo.reshape %21 : (tensor<1x2048x8192xbf16>) -> tensor<2048x8192xbf16> loc(#loc27)
    %23 = stablehlo.transpose %22, dims = [1, 0] {result_layout = dense<[0, 1]> : tensor<2xindex>, xla_shape = "bf16[8192,2048]{0,1}"} : (tensor<2048x8192xbf16>) -> tensor<8192x2048xbf16> loc(#loc28)
    %24 = stablehlo.dot_general %19, %23, contracting_dims = [1] x [0] : (tensor<1024x8192xbf16>, tensor<8192x2048xbf16>) -> tensor<1024x2048xbf16> loc(#loc29)
    %25 = stablehlo.reshape %24 : (tensor<1024x2048xbf16>) -> tensor<1x1024x2048xbf16> loc(#loc30)
    return %25 : tensor<1x1024x2048xbf16> loc(#loc)
  } loc(#loc)
} loc(#loc)
#loc = loc(unknown)
#loc5 = loc("custom-call.12")
#loc6 = loc("reshape.21")
#loc7 = loc("reshape.17")
#loc8 = loc("custom-call.18")
#loc9 = loc("reshape.19")
#loc10 = loc("transpose.20")
#loc11 = loc("dot.22")
#loc12 = loc("reshape.23")
#loc13 = loc("convert.24")
#loc14 = loc("logistic.25")
#loc15 = loc("multiply.26")
#loc16 = loc("convert.27")
#loc17 = loc("reshape.7")
#loc18 = loc("custom-call.8")
#loc19 = loc("reshape.9")
#loc20 = loc("transpose.10")
#loc21 = loc("dot.14")
#loc22 = loc("reshape.15")
#loc23 = loc("multiply.28")
#loc24 = loc("reshape.29")
#loc25 = loc("reshape.2")
#loc26 = loc("custom-call.3")
#loc27 = loc("reshape.4")
#loc28 = loc("transpose.5")
#loc29 = loc("dot.30")
#loc30 = loc("reshape.31")
