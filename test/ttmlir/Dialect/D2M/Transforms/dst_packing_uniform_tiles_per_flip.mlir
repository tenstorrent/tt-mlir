// RUN: ttmlir-opt --ttcore-register-device --d2m-generic-tile-compute-loops %s | FileCheck %s

// Regression test for the DstRegisterAnalysis fix that enforces a uniform
// (most restrictive) numTilesPerFlip across every linalg.generic in a fused
// d2m.generic region.
//
// Why this matters
// ----------------
// In a fused d2m.generic region, multiple linalg.generic ops can have
// different DST execution classes:
//   - SFPU ops (e.g. unary tile_exp / tile_sin / tile_neg) have half the DST
//     capacity of FPU ops.
//   - FPU ops (e.g. binary tile_add of two tile-typed bf16 operands) get the
//     full DST capacity.
// Independently, getLargestLegalChunkSize for each linalg can pick a different
// numTilesPerFlip, which D2MGenericTileComputeLoops then turns into different
// phase-2 inner-loop step sizes for the two linalgs in the same fused region.
//
// Non-uniform per-linalg phase-2 blocking inside one d2m.generic produces
// scratch-slot shapes that do not all line up: a producer's slot stored with
// one shape is then read by a consumer that iterates with a different
// blocking, and the index expressions generated by D2MInsertSpillAndScratch
// alias / skip tiles, corrupting the result.
//
// Pre-fusion (origin/main), all linalgs in an aliased chain shared the same
// DPS output Value, and the per-result merge in computeDSTPackingForRegion
// implicitly forced the most restrictive numTilesPerFlip. Once the
// elementwise-fusion fix gave each producer its own intermediate
// tensor.empty, the shared-Value assumption no longer held, so the analysis
// must explicitly normalize across the whole region.
//
// What this test asserts
// ----------------------
// A fused d2m.generic with two linalg.generic ops:
//   1. SFPU producer: tile_exp(%cb0) -> %tmp
//   2. FPU consumer:  tile_add(%tmp, %cb1) -> %cb2  (rhs is a TileType, so
//                     classifyComputeOp returns FPU)
// The shard size is 8x8 = 64 tiles. On bf16 with maxDstPhysicalSizeTiles=0
// (no override), getLargestLegalChunkSize gives:
//   - SFPU tile_exp: maxDstTiles = 8  -> numTilesPerFlip = 4
//   - FPU  tile_add: maxDstTiles = 16 -> numTilesPerFlip = 8
// Without the fix, the two linalg.generics would get different phase-2
// inner-loop step sizes (4 vs 8). With the fix, both are clamped to the
// smaller numTilesPerFlip (4) and emit `affine.for ... step 4` inside the
// scratch_space_loop. That uniform step is the visible signal of the fix.

#l1 = #ttcore.memory_space<l1>

// CHECK-LABEL: func.func @fused_sfpu_fpu_uniform_blocking
// Producer (tile_exp, SFPU): phase-2 inner loop steps by 4 tiles.
// CHECK:       affine.for
// CHECK-NEXT:    affine.for %{{.*}} = 0 to 8 step 4 {
// CHECK:           "d2m.tile_exp"
// CHECK:       } {d2m.scratch_space_loop}
// Consumer (tile_add, FPU): same phase-2 inner step (4), not 8.
// CHECK:       affine.for
// CHECK-NEXT:    affine.for %{{.*}} = 0 to 8 step 4 {
// CHECK:           "d2m.tile_add"
// CHECK:       } {d2m.scratch_space_loop}
// Negative check: the FPU linalg must NOT have been left with an unclamped
// step of 8, anywhere in this function.
// CHECK-NOT:   affine.for %{{.*}} = 0 to 8 step 8
func.func @fused_sfpu_fpu_uniform_blocking(
    %in0 : memref<1x1x8x8x!ttcore.tile<32x32, bf16>, #ttcore.shard<2048x2048, 1>, #l1>,
    %in1 : memref<1x1x8x8x!ttcore.tile<32x32, bf16>, #ttcore.shard<2048x2048, 1>, #l1>,
    %out0: memref<1x1x8x8x!ttcore.tile<32x32, bf16>, #ttcore.shard<2048x2048, 1>, #l1>) {
  d2m.generic {block_factors = [], grid = #ttcore.grid<1x1>,
               indexing_maps = [], iterator_types = [],
               threads = [#d2m.thread<unified>]}
      ins(%in0, %in1 : memref<1x1x8x8x!ttcore.tile<32x32, bf16>, #ttcore.shard<2048x2048, 1>, #l1>,
                       memref<1x1x8x8x!ttcore.tile<32x32, bf16>, #ttcore.shard<2048x2048, 1>, #l1>)
      outs(%out0 : memref<1x1x8x8x!ttcore.tile<32x32, bf16>, #ttcore.shard<2048x2048, 1>, #l1>) {
  ^unified0:
    %cb0_raw = d2m.get_cb(0) : !d2m.cb<memref<8x8x!ttcore.tile<32x32, bf16>, #l1>>
    %cb1_raw = d2m.get_cb(1) : !d2m.cb<memref<8x8x!ttcore.tile<32x32, bf16>, #l1>>
    %cb2_raw = d2m.get_cb(2) : !d2m.cb<memref<8x8x!ttcore.tile<32x32, bf16>, #l1>>
    %cb0 = d2m.wait %cb0_raw
        : !d2m.cb<memref<8x8x!ttcore.tile<32x32, bf16>, #l1>>
        -> memref<8x8x!ttcore.tile<32x32, bf16>, #l1>
    %cb1 = d2m.wait %cb1_raw
        : !d2m.cb<memref<8x8x!ttcore.tile<32x32, bf16>, #l1>>
        -> memref<8x8x!ttcore.tile<32x32, bf16>, #l1>
    %cb2 = d2m.reserve %cb2_raw
        : !d2m.cb<memref<8x8x!ttcore.tile<32x32, bf16>, #l1>>
        -> memref<8x8x!ttcore.tile<32x32, bf16>, #l1>
    // Producer-owned intermediate buffer (mirrors the post-fusion IR shape
    // produced by D2MElementwiseFusion's per-producer tensor.empty fix).
    %tmp = memref.alloc() {alignment = 64 : i64}
        : memref<8x8x!ttcore.tile<32x32, bf16>, #l1>
    // Producer: SFPU unary tile_exp(%cb0) -> %tmp.
    linalg.generic {
        indexing_maps = [affine_map<(d0, d1) -> (d0, d1)>,
                         affine_map<(d0, d1) -> (d0, d1)>],
        iterator_types = ["parallel", "parallel"]}
        ins(%cb0 : memref<8x8x!ttcore.tile<32x32, bf16>, #l1>)
        outs(%tmp : memref<8x8x!ttcore.tile<32x32, bf16>, #l1>) {
    ^bb0(%in: !ttcore.tile<32x32, bf16>, %out: !ttcore.tile<32x32, bf16>):
      %r = "d2m.tile_exp"(%in) : (!ttcore.tile<32x32, bf16>) -> !ttcore.tile<32x32, bf16>
      linalg.yield %r : !ttcore.tile<32x32, bf16>
    }
    // Consumer: FPU binary tile_add(%tmp, %cb1) -> %cb2. Both operands are
    // TileType, which is what classifyComputeOp routes to the FPU path.
    linalg.generic {
        indexing_maps = [affine_map<(d0, d1) -> (d0, d1)>,
                         affine_map<(d0, d1) -> (d0, d1)>,
                         affine_map<(d0, d1) -> (d0, d1)>],
        iterator_types = ["parallel", "parallel"]}
        ins(%tmp, %cb1 : memref<8x8x!ttcore.tile<32x32, bf16>, #l1>,
                         memref<8x8x!ttcore.tile<32x32, bf16>, #l1>)
        outs(%cb2 : memref<8x8x!ttcore.tile<32x32, bf16>, #l1>) {
    ^bb0(%a: !ttcore.tile<32x32, bf16>, %b: !ttcore.tile<32x32, bf16>, %out: !ttcore.tile<32x32, bf16>):
      %r = "d2m.tile_add"(%a, %b) : (!ttcore.tile<32x32, bf16>, !ttcore.tile<32x32, bf16>) -> !ttcore.tile<32x32, bf16>
      linalg.yield %r : !ttcore.tile<32x32, bf16>
    }
  }
  return
}
