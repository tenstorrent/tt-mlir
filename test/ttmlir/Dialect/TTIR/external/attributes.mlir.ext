// This file is meant to be injected with a `ttir.invoke_external` op; the
// `.ext` extension suffix prevents llvm-lit from parsing it directly.
//
// The #ttnn.ttnn_layout attribute alias lives only in this external file,
// hidden by a private helper function.

#l1     = #ttnn.buffer_type<l1>
#layout = #ttnn.ttnn_layout<(d0, d1) -> (d0, d1), <1x1>,
                             memref<2x4x!ttcore.tile<32x32, bf16>, #l1>,
                             <interleaved>>

module {
  func.func private @compute_with_layout(
      %arg0: tensor<64x128xbf16, #layout>) -> tensor<64x128xbf16, #layout> {
    return %arg0 : tensor<64x128xbf16, #layout>
  }

  // Public entry point – plain tensor types visible to the caller module.
  func.func @compute(%arg0: tensor<64x128xbf16>) -> tensor<64x128xbf16> {
    return %arg0 : tensor<64x128xbf16>
  }
}
