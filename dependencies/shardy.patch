+++
+++if(LLVM_ENABLE_ZLIB)
+++  find_package(ZLIB)
+++endif()
+++
+++#-------------------------------------------------------------------------------
+++# Compiler options
+++#-------------------------------------------------------------------------------
+++
+++#-------------------------------------------------------------------------------
+++# Performance configuration
+++#-------------------------------------------------------------------------------
+++
+++include(CheckCXXCompilerFlag)
+++include(CheckLinkerFlag)
