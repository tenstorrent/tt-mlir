[
    {
        "runs-on": "llmbox",
        "image": "speedy",
        "script": "ttrt.sh",
        "args": [
            "run",
            "Silicon",
            "--fabric-config",
            "fabric_1d_ring"
        ]
    },
    {
        "runs-on": "llmbox",
        "image": "tracy",
        "script": "ttrt.sh",
        "args": [
            "perf",
            "Silicon/TTNN/llmbox/perf"
        ]
    },
    {
        "runs-on": "llmbox",
        "image": "tracy",
        "script": "ttrt.sh",
        "args": [
            "perf",
            "Silicon/TTNN/llmbox/perf/ring",
            "--fabric-config",
            "fabric_1d_ring"
        ]
    },
    {
        "runs-on": "llmbox",
        "image": "tracy",
        "script": "builder.sh",
        "args": [
            "test/python/golden",
            "",
            "run-ttrt"
        ]
    },
    {
        "runs-on": "llmbox",
        "image": "tracy",
        "script": "ttnn_runtime.sh",
        "args": "runtime/test/ttnn/python/distributed/llmbox"
    },
    {
        "runs-on": "llmbox",
        "image": "tracy",
        "script": "ttnn_jit.sh"
    }
]
